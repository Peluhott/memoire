// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id                 Int          @id @default(autoincrement())
  username           String       @unique
  password           String
  email              String       @unique
  healthData         HealthData[]
  content            content[]
  limit_upload       Int
  limit_connections  Int
  connectionsA       Connection[] @relation("connectionsA")
  connectionsB       Connection[] @relation("connectionsB")
  deliveriesReceived Delivery[]   @relation("DeliveriesReceived")
  deliveriesSent     Delivery[]   @relation("DeliveriesSent")
}

model content {
  id                  Int        @id @default(autoincrement())
  user_id             Int
  user                user       @relation(fields: [user_id], references: [id])
  public_id           String
  resource_type       String
  type                String
  title               String
  description         String
  shared_with_network Boolean
  uploaded_at         DateTime   @default(now())
  deliveries          Delivery[]
}

model HealthData {
  id        Int        @id @default(autoincrement())
  user      user       @relation(fields: [userId], references: [id])
  userId    Int
  type      HealthType
  value     Float?
  createdAt DateTime?

  @@unique([userId, type]) // will be able to search by userid and type
}

enum HealthType {
  hrvBaseline
  rhrBaseline
  sleepBaseline
  stepsBaseline
}

model Connection {
  id        Int              @id @default(autoincrement())
  userA     user             @relation("connectionsA", fields: [userAId], references: [id])
  userAId   Int
  userB     user             @relation("connectionsB", fields: [userBId], references: [id])
  userBId   Int
  requester Int // <-- who initiated the request (user id)
  status    ConnectionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userAId, userBId])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum DeliveryStatus {
  DELIVERED
  OPENED
  EXPIRED
  FAILED
}

model Delivery {
  id         Int            @id @default(autoincrement())
  contentId  Int
  receiverId Int
  senderId   Int
  timesSeen  Int            @default(0)
  dateSent   DateTime       @default(now())
  dateSeen   DateTime?
  status     DeliveryStatus @default(DELIVERED)
  // expiresAt is set by the database to 24 hours after insertion
  expiresAt  DateTime       @default(dbgenerated("now() + interval '24 hours'"))

  // Relations
  content  content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  receiver user    @relation("DeliveriesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  sender   user    @relation("DeliveriesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([receiverId, dateSent], map: "idx_delivery_receiver_datesent")
  @@index([contentId, receiverId], map: "idx_delivery_content_receiver")
  @@index([senderId], map: "idx_delivery_sender")
  @@index([expiresAt], map: "idx_delivery_expiresat")
}
