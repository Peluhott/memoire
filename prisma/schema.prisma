// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id                Int          @id @default(autoincrement())
  username          String       @unique
  password          String
  email             String       @unique
  healthData        HealthData[]
  content           content[]
  limit_upload      Int
  limit_connections Int
}

model content {
  id                  Int      @id @default(autoincrement())
  user_id             Int
  user                user     @relation(fields: [user_id], references: [id])
  public_id           String
  resource_type       String
  type                String
  title               String
  description         String
  shared_with_network Boolean
  uploaded_at         DateTime @default(now())
}

model HealthData {
  id        Int        @id @default(autoincrement())
  user      user       @relation(fields: [userId], references: [id])
  userId    Int
  type      HealthType
  value     Float?
  createdAt DateTime?

  @@unique([userId, type]) // will be able to search by userid and type
}

enum HealthType {
  hrvBaseline
  rhrBaseline
  sleepBaseline
  stepsBaseline
}
